# ── REQUIRED ────────────────────────────────────────────────────
GCP_PROJECT: your-gcp-project-id

# Twilio WhatsApp API credentials (store in GCP Secret Manager for production)
TWILIO_ACCOUNT_SID: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN: your_auth_token_here
TWILIO_WHATSAPP_NUMBER: "+14155238886"

# ── PRODUCTION ONLY ────────────────────────────────────────────
# Twilio signature verification is always enabled in Cloud Run (K_SERVICE set)
# No manual flag needed -- the API checks for K_SERVICE automatically
